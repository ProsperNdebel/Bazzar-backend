# --- Development (default): SQLite, no server needed ---
# Leave DATABASE_URL unset to use ./bazaar.db, or set it explicitly:
# DATABASE_URL=sqlite+aiosqlite:///./bazaar.db

# --- Production: Postgres ---
# DATABASE_URL=postgresql+asyncpg://bazaar:bazaar@localhost:5432/bazaar

JWT_SECRET=replace-with-a-long-random-string
ACCESS_TOKEN_TTL_MINUTES=10080
TAX_RATE=0.095
